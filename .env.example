# Copy to .env (root-level shared env for docker-compose).
# Per-service env files live alongside each service.

# --- Postgres ---
POSTGRES_USER=threadloop
POSTGRES_PASSWORD=threadloop
POSTGRES_DB=threadloop

# --- Backend ---
BACKEND_PORT=8000
DATABASE_URL=postgresql+psycopg://threadloop:threadloop@postgres:5432/threadloop
REDIS_URL=redis://redis:6379/0
MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=dev-master-key-change-me
CORS_ORIGINS=http://localhost:5173,http://localhost:19006

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:8000
# Google OAuth Web client id; required for the slice-1 sign-in page (#19) to
# initialize Google Identity Services. Without it, /sign-in renders a clear
# configuration error instead of a broken button. Same Google project as
# `GOOGLE_CLIENT_ID` below — they share the audience claim the backend checks.
VITE_GOOGLE_CLIENT_ID=
# Apple Service ID for the slice-2 (#38) Sign in with Apple JS SDK on web.
# Required when `APPLE_ENABLED=true` below; otherwise the Apple button
# renders disabled. Must match `APPLE_CLIENT_ID` below exactly — the
# backend's Apple JWKS verifier checks `aud` against that value.
VITE_APPLE_CLIENT_ID=
# Optional Apple redirect URI override. Defaults to `window.location.origin`,
# which matches a same-origin Apple Service ID. Set when the build is served
# from a different origin than the registered return URL (e.g. previews).
VITE_APPLE_REDIRECT_URI=

# --- Auth feature flag ---
# Master flag for the SSO subsystem (RFC 0001 § Rollout plan step 1). While
# this is `false`, every `/api/auth/*` route returns 404. Production deploys
# must set this to `true` only after step 5 (all three providers validated in
# staging); staging flips it earlier at step 3.
#
# When `AUTH_ENABLED=true`, JWT_SIGNING_KEY and REFRESH_TOKEN_HMAC_KEY must
# be set non-empty (cross-cutting — every provider's session helpers reach
# for them). Per-provider secrets are required only when that provider's
# `*_ENABLED` flag below is `true` — see issue #51 for the rationale.
AUTH_ENABLED=false

# --- Per-provider enablement ---
# Mirrors Epic #11's slice-by-slice rollout. Slice 1 = Google only, slice 2
# adds Apple, slice 3 adds Facebook. Each provider's callback returns 404
# when its flag is `false` (same envelope as the master AUTH_ENABLED 404),
# and `Settings()` refuses to construct if the provider is enabled but its
# secrets are unset. A slice-1 demo therefore needs only AUTH_ENABLED=true
# + GOOGLE_ENABLED=true + the Google + cross-cutting secrets — no dummy
# Apple/Facebook values required.
GOOGLE_ENABLED=false
APPLE_ENABLED=false
FACEBOOK_ENABLED=false

# --- Auth secrets ---
# Required when AUTH_ENABLED=true (cross-cutting). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SIGNING_KEY=
REFRESH_TOKEN_HMAC_KEY=

# --- SSO (filled in later, leave blank for scaffold) ---
# GOOGLE_CLIENT_ID is required when GOOGLE_ENABLED=true.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Apple secrets are required when APPLE_ENABLED=true.
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
# Facebook Login uses APP_ID / APP_SECRET (Meta for Developers naming),
# matching the `facebook_app_id` / `facebook_app_secret` fields in
# backend/app/config.py:Settings. Both are required when FACEBOOK_ENABLED=true.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
